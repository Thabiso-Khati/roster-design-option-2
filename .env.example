# ============================================
# ROSTER V3 — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================

# Supabase (get from https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack — checkout, subscriptions, expert subaccount payouts
# (https://dashboard.paystack.com → Settings → API Keys & Webhooks)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Paystack Recurring Plan Codes
# Create one plan per tier+billing in Paystack dashboard → Products → Plans
# Set the interval (monthly/annually) and the ZAR amount for each.
# Format: PLN_xxxxxxxxxxxxxxxx
#
# Pro  — R599/mo, R5,990/yr
PAYSTACK_PRO_MONTHLY_PLAN_CODE=PLN_
PAYSTACK_PRO_ANNUAL_PLAN_CODE=PLN_
# Legacy aliases (used as fallback for Pro if the PRO_ vars above are not set)
PAYSTACK_MONTHLY_PLAN_CODE=PLN_cgub2fwdlt93ioe
PAYSTACK_ANNUAL_PLAN_CODE=PLN_av9w1ycxegzr5vy
#
# Agency  — R1,299/mo, R12,990/yr  ⚠️  REQUIRED before Agency checkout goes live
PAYSTACK_AGENCY_MONTHLY_PLAN_CODE=PLN_
PAYSTACK_AGENCY_ANNUAL_PLAN_CODE=PLN_
#
# Enterprise  — R4,999/mo, R49,990/yr  ⚠️  REQUIRED before Enterprise checkout goes live
PAYSTACK_ENTERPRISE_MONTHLY_PLAN_CODE=PLN_
PAYSTACK_ENTERPRISE_ANNUAL_PLAN_CODE=PLN_

# Anthropic — powers the AI tools (Brand Studio, Pitching Scripts, Viral Hooks, etc.)
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Daily.co — video meetings for expert sessions
# Get from https://dashboard.daily.co → Developers
DAILY_API_KEY=your_daily_api_key
DAILY_DOMAIN=your-subdomain.daily.co
# Used to verify webhook payloads from Daily.co — get from Daily dashboard → Webhooks
DAILY_WEBHOOK_SECRET=

# Spotify — artist OAuth + monthly listener data + S4A metrics
# Get from https://developer.spotify.com/dashboard → Create app
# Important: redirect URI in Spotify dashboard MUST use 127.0.0.1 in dev
# (Spotify no longer accepts http://localhost) — e.g.
#   http://127.0.0.1:3001/api/spotify/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# TikTok — per-artist OAuth (Content Posting API v2)
# Tokens are stored per-ARTIST (not per-user) in artist_tiktok_tokens.
# Apply at https://developers.tiktok.com → Manage Apps → Create App
# Required scopes: user.info.basic, user.info.profile, user.info.stats, video.list
# Redirect URI to register: <NEXT_PUBLIC_APP_URL>/api/tiktok/callback
# ⚠️  TikTok Developer app review is required before OAuth works in production.
#     In sandbox mode only approved test users can connect.
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Resend (email) — get from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=ROSTER <noreply@rosterapp.ai>

# WhatsApp & SMS (Africa's Talking — africastalking.com)
AFRICASTALKING_API_KEY=your_africastalking_api_key
AFRICASTALKING_USERNAME=your_at_username
NEXT_PUBLIC_SUPPORT_WHATSAPP=+27XXXXXXXXX   # Your ROSTER support WhatsApp number

# Admin access (comma-separated email addresses)
ADMIN_EMAILS=your@email.com

# Dev tooling — set to "1" to enable /api/dev/create-test-booking and other
# dev-only endpoints. Leave unset in production.
ROSTER_ALLOW_DEV_TOOLS=

# Audiomack — artist followers + verified plays (West Africa key platform)
# Apply at https://developer.audiomack.com
# Uses OAuth 1.0a (two-legged / consumer credentials).
AUDIOMACK_CONSUMER_KEY=your_audiomack_consumer_key
AUDIOMACK_CONSUMER_SECRET=your_audiomack_consumer_secret

# Boomplay — artist streams + followers (Africa's largest streaming platform)
# Apply at https://developer.boomplay.com or email developer@boomplay.com
# Uses OAuth 2.0 client_credentials. Partner API requires approval.
# lib/boomplay/client.ts uses the CLIENT_ID/SECRET pair (standard OAuth naming).
# lib/fetchers/boomplay.ts uses APP_ID/APP_SECRET (Boomplay's own field names).
# These are the same credential set — copy the same values to both pairs.
BOOMPLAY_CLIENT_ID=your_boomplay_client_id
BOOMPLAY_CLIENT_SECRET=your_boomplay_client_secret
BOOMPLAY_APP_ID=your_boomplay_client_id       # same value as BOOMPLAY_CLIENT_ID
BOOMPLAY_APP_SECRET=your_boomplay_client_secret # same value as BOOMPLAY_CLIENT_SECRET

# YouTube Data API v3 — powers the nightly auto-pull of subscribers
# and views_28d for every artist. Free tier = 10,000 units/day, more
# than enough for a few thousand artists.
# Get from https://console.cloud.google.com → APIs & Services →
# Credentials → Create Credentials → API Key, then enable "YouTube
# Data API v3" on that project.
YOUTUBE_API_KEY=

# Cron auth — any long random string. Used by /api/cron/fetch-stats
# to verify the nightly fetcher request actually came from the Vercel
# cron (or your local scheduled task). Generate with:
#   openssl rand -hex 32
CRON_SECRET=

# App
# Note: V3 runs on port 3001 to keep Spotify OAuth happy. Update Spotify
# redirect URIs accordingly.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_NAME=ROSTER


# ── Upstash Redis — distributed rate limiting ─────────────────────────────────
# Required for production-grade rate limiting across all Vercel edge instances.
# Without this, rate limiting only works per-instance (not shared).
# Create a Redis database at https://console.upstash.com → Create Database
# Then copy the REST URL and token from the database's REST API tab.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx_your_token_here
# ── Observability ──────────────────────────────��────────────────────────���─────
# Run `bash scripts/setup-observability.sh` to install packages and verify keys.

# Sentry — error tracking, session replay, cron monitoring
# Get DSN from: https://sentry.io → your project → Settings → SDK Setup
# NEXT_PUBLIC_ prefix is required so the browser SDK can use it.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry CLI / build-time source-map upload
# Get from: https://sentry.io → Settings → Auth Tokens → Create (org:read, project:releases)
SENTRY_ORG=jo-la-labs
SENTRY_PROJECT=roster-v3
SENTRY_AUTH_TOKEN=

# PostHog — product analytics and feature flags
# Get from: https://app.posthog.com → Project Settings → Project API key
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog ingestion host — use your region's endpoint or self-hosted URL.
# EU: https://eu.i.posthog.com  |  US: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── E-Sign token secret ────────────────────────────────────────────────────────
# 32-char+ random string used to sign esign JWT tokens.
# Falls back to SUPABASE_SERVICE_ROLE_KEY if not set, but an explicit
# value is recommended for security isolation.
# Generate with: openssl rand -hex 32
ESIGN_TOKEN_SECRET=

# ── Logging ────────────────────────────────────────────────────────────────────
# Controls lib/logger.ts verbosity. Leave unset in production (defaults to
# "info"). Set to "debug" to see verbose output in local development.
# Valid values: debug | info | warn | error
LOG_LEVEL=

# ── NextAuth secret (legacy fallback) ─────────────────────────────────────────
# Used as a fallback HMAC secret in lib/sign/tokens.ts when ESIGN_TOKEN_SECRET
# is not set. Not required if ESIGN_TOKEN_SECRET is configured.
NEXTAUTH_SECRET=
