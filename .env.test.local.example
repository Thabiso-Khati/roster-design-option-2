# ============================================
# ROSTER V3 — E2E Test Credentials
# Copy this file to .env.test.local and fill in your values
# NEVER commit .env.test.local to git
# ============================================

# A real Supabase user in your TEST project.
# Must have an active subscription (Pro tier is sufficient).
# Do NOT use production credentials here.
E2E_TEST_EMAIL=your-test-user@example.com
E2E_TEST_PASSWORD=your-test-password
